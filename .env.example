# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/connexion
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/inscription
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Issuer Clerk (Frontend API URL) — doit correspondre aux clés ci-dessus
# Ex: https://ruling-prawn-6.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# Convex — après `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
